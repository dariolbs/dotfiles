cmd copyimage ${{
	case $f in
		*.png)
			xclip -selection clipboard -t image/png -i $f
			;;
		*.jpg)
			xclip -selection clipboard -t image/jpg -i $f
			;;
		*.jpeg)
			xclip -selection clipboard -t image/jpeg -i $f
			;;
		esac
}}

cmd trash ${{
	if [ -z "$fs" ]; then
		trash-put $f
	else
		trash-put $fs
	fi
    #lf -remote 'send reload'
}}

# Forces removing a file
cmd forcerm ${{
	if [ -z "$fs" ]; then
		rm -rfi $f
	else
		rm -rfi $fs
	fi
}}

# Shreds and removes files.
# Safer option if you want to delete somthing without
# the possibility of it being restored
cmd shredandrm ${{
	if [ -z "$fs" ]; then
        printf "Do you really want to delete (and shred) %s?" $f
        read r
        case $r in
            "yes" | "y")
                shred $f &&
                rm -rf $f
                ;;
        esac
	else
        printf "Do you really want to delete (and shred) %s? (yes/no) " $f
        read r
        case $r in
            "yes" | "y")
                shred $fs &&
                rm -rf $fs
                ;;
        esac
	fi
}}

cmd cdfuzzy ${{
    file="$(fzf)"
    [ -n $file ] && cd "${file%/*}"
}}

cmd nvimfuzzy ${{
    file="$(fzf)"
    [ -n $file ] && $EDITOR "$file"
}}

cmd open ${{
    case $(file --mime-type "$f" -bL) in
         text/* | inode/x-empty | application/json) $EDITOR "$f";;
         image/gif | inode/x-empty | application/json) nsxiv -a "$f" &;;
        #video/*|image/*/application/pdf) xdg-open "$f" & ;;
        *) xdg-open "$f" &> /dev/null & disown;;
    esac
}}

cmd opensxiv ${{
	nsxiv -t * &
}}

cmd syncrepo ${{
	printf "Commit message: "
	read message 
	git commit -a -m "$message"
	git push
}}

cmd gitadd ${{
	if [ -z "$fs" ]; then
		git add $f
	else
		git add $fs
	fi
}}

