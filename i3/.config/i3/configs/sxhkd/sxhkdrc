# SXHKD Config - Dário Batista

XF86AudioPrev
	playerctl previous
XF86AudioNext
	playerctl next
XF86AudioPlay
	playerctl play-pause

# Scripts

mod4 + shift + p
	bash ~/.config/i3/configs/sxhkd/scripts/system_config/configure_system
mod4 + shift + b
	bash ~/.config/i3/configs/sxhkd/scripts/bookmark
Print
	bash ~/.config/i3/configs/sxhkd/scripts/print_monitor
mod4 + Print
	sh ~/.config/i3/configs/sxhkd/scripts/print
mod4 + e
	sh ~/.config/i3/configs/sxhkd/scripts/emoji_picker/script
XF86AudioRaiseVolume
	sh ~/.config/i3/configs/sxhkd/scripts/volume +5
XF86AudioLowerVolume
	sh ~/.config/i3/configs/sxhkd/scripts/volume -5
XF86AudioMute
	sh ~/.config/i3/configs/sxhkd/scripts/volume-toggle

# File managers
mod4 + n
	touch /tmp/yazi-launcher && st

# Programas
mod4 + w
	firefox

XF86Calculator
	st calc

XF86Mail
	st neomutt

XF86Tools
	st ncmpcpp

mod4 + shift + q
	xkill
