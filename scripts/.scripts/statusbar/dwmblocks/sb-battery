#!/bin/sh

# Prints all batteries, their percentage remaining and an emoji corresponding
# to charge status (َ°‚„ for plugged up, ًں”‹ for discharging on battery, etc.).

case $BLOCK_BUTTON in
	3) notify-send "ًں”‹ Battery module" "ًں”‹: discharging
ًں›‘: not charging
â™»: stagnant charge
ًں”Œ: charging
âڑ،: charged
â‌—: battery very low!
- Scroll to change adjust xbacklight." ;;
	4) xbacklight -inc 10 ;;
	5) xbacklight -dec 10 ;;
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac


show_controller=false
show_battery=true
# Loop through all attached batteries and format the info
for battery in $(upower -i $(upower -e | grep gip) | grep "percentage" | awk '{ print $2 }' | sed "s/%//"); do
    ccapacity=$(upower -i $(upower -e | grep gip) | grep "percentage" | awk '{ print $2 }' | sed "s/%//")
    [ -z "$ccapacity" ] && continue
    case 1 in
        $((ccapacity >= 70)) ) cstatus="َ°‌چ";;
        $((ccapacity >= 40)) ) cstatus="َ°‌ڈ";;
        $((ccapacity >= 10)) ) cstatus="َ°‌ژ";;
        *) cstatus="َ°‌Œ";;
    esac
    show_controller=true
done

# Loop through all attached batteries and format the info
for battery in /sys/class/power_supply/BAT?*; do
	# If non-first battery, print a space separator.
	[ -n "${capacity+x}" ] && printf " "
	# Sets up the status and capacity
	case "$(cat "$battery/status" 2>&1)" in
		"Full") status="َ±ں¢" ;;
		"Discharging" | "Not charging")
            capacity="$(cat "$battery/capacity" 2>&1)"
            case 1 in
            $((capacity >= 90)) ) status="َ°پ¹";;
            $((capacity >= 80)) ) status="َ°‚‚";;
            $((capacity >= 70)) ) status="َ°‚پ";;
            $((capacity >= 60)) ) status="َ°پ؟";;
            $((capacity >= 50)) ) status="َ°پ¾";;
            $((capacity >= 40)) ) status="َ°پ½";;
            $((capacity >= 30)) ) status="َ°پ¼";;
            $((capacity >= 20)) ) status="َ°پ»";;
            $((capacity >= 10)) ) status="َ°پ؛";;
            *) status="َ°‚ژ";;
            esac
            ;;
		"Charging")
            capacity="$(cat "$battery/capacity" 2>&1)"
            case 1 in
                $((capacity >= 90)) ) status="َ°‚…";;
                $((capacity >= 80)) ) status="َ°‚‹";;
                $((capacity >= 70)) ) status="َ°‚ٹ";;
                $((capacity >= 60)) ) status="َ°¢‍";;
                $((capacity >= 50)) ) status="َ°‚‰";;
                $((capacity >= 40)) ) status="َ°¢‌";;
                $((capacity >= 30)) ) status="َ°‚ˆ";;
                $((capacity >= 20)) ) status="َ°‚†";;
                $((capacity >= 10)) ) status="َ°¢œ";;
                *) status="َ°¢ں" ;;
            esac
            ;;
		"Unknown") status="?" ;;
		*) show_battery=false ;;
	esac
	capacity="$(cat "$battery/capacity" 2>&1)"
	# Prints the info
    [ $show_controller = true ] && printf "%s %d%%" "$cstatus" "$ccapacity"
    [ $show_battery = true ] && printf "%s %d%%" "$status" "$capacity"; unset warn
done && printf "\\n"
