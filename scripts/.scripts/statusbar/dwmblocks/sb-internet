#!/bin/sh

if grep -xq 'up' /sys/class/net/w*/operstate 2>/dev/null ; then
    percentage=$(awk '/^\s*w/ { print int($3 * 100 / 70) }' /proc/net/wireless)
    case 1 in
        $((percentage >= 85)) ) icon="ůį§®";;
        $((percentage >= 60)) ) icon="ůį§•";;
        $((percentage >= 40)) ) icon="ůį§Ę";;
        $((percentage >= 20)) ) icon="ůį§ü";;
        $((percentage >= 1)) ) icon="ůį§Į";;
    esac
    wifiicon="$icon ${percentage}%"
elif grep -xq 'down' /sys/class/net/w*/operstate 2>/dev/null ; then
	grep -xq '0x1003' /sys/class/net/w*/flags && wifiicon="ůį§ģ " || wifiicon="ůį§ę "
fi

printf "%s%s%s\n" "$wifiicon" "$(sed "s/down/ůįąā down/;s/up//" /sys/class/net/e*/operstate 2>/dev/null)" "$(sed "s/.*/ūüĒí/" /sys/class/net/tun*/operstate 2>/dev/null)"
